def parse_mg(txt: str) -> Optional[float]:
    """Extrai valor numérico de texto (em mg)"""
    if not txt:
        return None
    m = re.search(r"(\d+(?:[.,]\d+)?)", txt)
    return float(m.group(1).replace(",", ".")) if m else None


def format_med(nome: str, dose: Optional[float]) -> str:
    """Formata o medicamento com dose ou 'desconhecida'"""
    return f"{nome} ({dose} mg)" if dose is not None else f"{nome} (unknown dose)"


def main() -> None:
    # Escolha de idioma
    lang = ""
    while lang not in ("pt", "en"):
        lang = input("Escolha o idioma / Choose language (pt/en): ").strip().lower()

    msg = MESSAGES[lang]

    print(msg["welcome"])
    print(msg["intro"])

    # Quantidade de medicamentos
    n = 0
    while n < 1:
        try:
            n = int(input(msg["how_many"]))
            if n < 1:
                print(msg["need_one"])
        except ValueError:
            print(msg["need_number"])

    # Coleta dos medicamentos
    meds = []
    for i in range(1, n + 1):
        nome = input(msg["med_name"].format(i)).strip()
        dose_raw = input(msg["med_dose"]).strip() or None
        dose = parse_mg(dose_raw)
        meds.append((nome, dose))
        print(msg["noted"])

    print(msg["summary"])
    for nome, dose in meds:
        print("•", format_med(nome, dose))

    # Monta pergunta sobre interação
    pergunta_interacao = (
        ("os remédios " if lang == "pt" else "do the medications ")
        + ", ".join(format_med(n, d) for n, d in meds)
        + (" têm alguma interação medicamentosa?" if lang == "pt" else " have any drug interactions?")
    )

    print(msg["checking"])
    resposta_interacao = call_gpt(pergunta_interacao)

    print(msg["result"])
    print(resposta_interacao)

    # Dicas de uso (horários e alimentos)
    if input(msg["ask_tips"]).strip().lower() == msg["yes"]:
        pergunta_dicas = (
            ("quais os melhores horários, intervalos e combinações alimentares para tomar "
             if lang == "pt" else
             "what are the best times, intervals, and food combinations for taking ")
            + ", ".join(n for n, _ in meds)
            + ("? cite interações com alimentos se relevante." if lang == "pt"
               else "? mention food interactions if relevant.")
        )
        print(msg["getting_tips"])
        dicas_uso = call_gpt(pergunta_dicas)

        print(msg["tips"])
        print(dicas_uso)

    print(msg["bye"])


if __name__ == "__main__":
    main()
